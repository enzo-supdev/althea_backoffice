  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) pm.collectionVariables.set('baseUrl', 'https://api-pslt.matheovieilleville.fr');",
          "if (!pm.collectionVariables.get('apiPrefix')) pm.collectionVariables.set('apiPrefix', '/api/v1');"
        ]
      }
    }
  ],
